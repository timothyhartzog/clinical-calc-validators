      "expected_output": {
        "resistance_mmhg_min_ml": 640.0,
        "resistance_wood_units": 8.0,
        "indexed_resistance": 8.0,
        "interpretation": "low (septic shock)"
      },
      "source": "Sepsis criteria and hemodynamic classification",
      "reference_url": "https://pubmed.ncbi.nlm.nih.gov/",
      "calculation_method": "SVR = (70-6)/8 = 8 Wood units (640 mmHg·min/mL)",
      "verified_by": "Timothy Hartzog, MD",
      "confidence": "HIGH",
      "tolerance": 0.005,
      "notes": "Very low SVR with elevated CO is hallmark of septic shock"
    },
