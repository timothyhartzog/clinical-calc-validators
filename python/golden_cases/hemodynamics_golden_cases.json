    {
      "id": "CARDIAC_INDEX_NORMAL_001",
      "clinical_scenario": "Healthy 7-year-old with normal CI",
      "calculation_type": "cardiac_index",
      "inputs": {
        "cardiac_output_ml_min": 4200,
        "body_surface_area_m2": 1.0
      },
      "expected_output": {
        "cardiac_index_ml_min_m2": 4.2,
        "interpretation": "normal"
      },
      "source": "PALS guidelines for cardiac index",
      "reference_url": "https://pubmed.ncbi.nlm.nih.gov/",
      "calculation_method": "CI = (CO in L/min) / BSA = (4.2 L/min) / 1.0 = 4.2 L/min/m²",
      "verified_by": "Timothy Hartzog, MD",
      "confidence": "HIGH",
      "tolerance": 0.005,
      "notes": "CI 3.5-4.5 L/min/m2 normal; this value is at mid-normal"
    },
    {
      "id": "CARDIAC_INDEX_LOW_001",
      "clinical_scenario": "Child with cardiogenic shock and reduced cardiac index",
      "calculation_type": "cardiac_index",
      "inputs": {
        "cardiac_output_ml_min": 2000,
        "body_surface_area_m2": 1.0
      },
      "expected_output": {
        "cardiac_index_ml_min_m2": 2.0,
        "interpretation": "low"
      },
      "source": "Shock classification in pediatrics",
      "reference_url": "https://pubmed.ncbi.nlm.nih.gov/",
      "calculation_method": "CI = (CO in L/min) / BSA = (2.0 L/min) / 1.0 = 2.0 L/min/m²",
      "verified_by": "Timothy Hartzog, MD",
      "confidence": "HIGH",
      "tolerance": 0.005,
      "notes": "CI <2.5 L/min/m2 indicates cardiogenic shock"
    },
    {
      "id": "SVR_NORMAL_001",
      "clinical_scenario": "Normal hemodynamics: MAP 80, CVP 5, CO 4000, BSA 1.0",
      "calculation_type": "systemic_vascular_resistance",
      "inputs": {
        "mean_arterial_pressure": 80,
        "central_venous_pressure": 5,
        "cardiac_output_ml_min": 4000,
        "body_surface_area_m2": 1.0
      },
      "expected_output": {
        "resistance_mmhg_min_ml": 1500.0,
        "resistance_wood_units": 18.75,
        "indexed_resistance": 1500.0,
        "interpretation": "normal"
      },
      "source": "PALS vascular resistance calculation",
      "reference_url": "https://pubmed.ncbi.nlm.nih.gov/",
      "calculation_method": "SVR = (80-5)/4000 × 80 = 1500 mmHg·min/mL (18.75 Wood units)",
      "verified_by": "Timothy Hartzog, MD",
      "confidence": "HIGH",
      "tolerance": 0.005,
      "notes": "Normal SVR 15-20 Wood units"
    },
    {
      "id": "SVR_LOW_SEPSIS_001",
