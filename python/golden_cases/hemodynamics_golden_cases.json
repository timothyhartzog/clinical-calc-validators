  "hemodynamic_calculations": [
    {
      "id": "MAP_NORMAL_6YO_001",
      "clinical_scenario": "Healthy 6-year-old with normal vital signs during routine evaluation",
      "calculation_type": "mean_arterial_pressure",
      "inputs": {
        "systolic_bp": 105,
        "diastolic_bp": 65,
        "age_months": 72
      },
      "expected_output": {
        "mean_arterial_pressure": 78.33,
        "interpretation": "normal"
      },
      "source": "PALS guidelines normal MAP for school-age child",
      "reference_url": "https://pubmed.ncbi.nlm.nih.gov/",
      "calculation_method": "MAP = (105 + 2×65) / 3 = 78.33 mmHg",
      "verified_by": "Timothy Hartzog, MD",
      "confidence": "HIGH",
      "tolerance": 0.005,
      "notes": "Normal blood pressure for age"
    },
    {
